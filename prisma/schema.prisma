generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum SubscriptionTier {
  FREE
  PRO
  PRO_STR
}

enum PropertyType {
  LONG_TERM
  SHORT_TERM
}

enum PropertyStatus {
  ACTIVE
  ARCHIVED
}

enum UnitStatus {
  OCCUPIED
  VACANT
  MAINTENANCE
}

enum TenantStatus {
  ACTIVE
  ARCHIVED
}

enum LeaseRenewalStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  MONTH_TO_MONTH
  RENEWED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum MaintenanceStatus {
  SUBMITTED
  ACKNOWLEDGED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum CommunicationMethod {
  CALL
  TEXT
  EMAIL
  IN_PERSON
  OTHER
}

enum BookingPlatform {
  AIRBNB
  VRBO
  DIRECT
  OTHER
}

enum BookingStatus {
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum CleaningStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  INSPECTED
}

// ─── Auth Models (NextAuth Adapter) ─────────────────────────────────────────

model User {
  id                   String           @id @default(cuid())
  email                String           @unique
  emailVerified        DateTime?
  name                 String?
  passwordHash         String?
  businessName         String?
  phone                String?
  image                String?
  subscriptionTier     SubscriptionTier @default(FREE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  accounts      Account[]
  sessions      Session[]
  properties    Property[]
  tenants       Tenant[]
  vendors       Vendor[]
  guests        Guest[]
  notifications Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ────────────────────────────────────────────────────────────

model Property {
  id             String         @id @default(cuid())
  userId         String
  name           String
  address        String
  city           String
  state          String
  zipCode        String
  type           PropertyType
  photos         String[]
  purchasePrice  Decimal?
  purchaseDate   DateTime?
  mortgageAmount Decimal?
  insuranceCost  Decimal?
  propertyTax    Decimal?
  notes          String?        @db.Text
  status         PropertyStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  units               Unit[]
  transactions        Transaction[]
  maintenanceRequests MaintenanceRequest[]
  documents           Document[]

  @@index([userId])
}

model Unit {
  id            String     @id @default(cuid())
  propertyId    String
  label         String
  bedrooms      Int?
  bathrooms     Decimal?
  squareFootage Int?
  status        UnitStatus @default(VACANT)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  property            Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant              Tenant?
  leases              Lease[]
  transactions        Transaction[]
  maintenanceRequests MaintenanceRequest[]
  bookings            Booking[]
  cleaningTasks       CleaningTask[]
  documents           Document[]
}

model Tenant {
  id               String       @id @default(cuid())
  userId           String
  unitId           String?      @unique
  name             String
  email            String?
  phone            String?
  emergencyContact String?
  emergencyPhone   String?
  moveInDate       DateTime?
  moveOutDate      DateTime?
  notes            String?      @db.Text
  status           TenantStatus @default(ACTIVE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit              Unit?              @relation(fields: [unitId], references: [id], onDelete: SetNull)
  leases            Lease[]
  transactions      Transaction[]
  maintenanceRequests MaintenanceRequest[]
  documents         Document[]
  communicationLogs CommunicationLog[]
}

model Lease {
  id              String             @id @default(cuid())
  unitId          String
  tenantId        String
  startDate       DateTime
  endDate         DateTime
  monthlyRent     Decimal
  securityDeposit Decimal?
  renewalStatus   LeaseRenewalStatus @default(ACTIVE)
  terms           String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  unit      Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([endDate])
}

model Transaction {
  id                  String            @id @default(cuid())
  propertyId          String
  unitId              String?
  tenantId            String?
  vendorId            String?
  type                TransactionType
  category            String
  amount              Decimal
  date                DateTime
  paymentMethod       String?
  payee               String?
  payer               String?
  receiptUrl          String?
  notes               String?           @db.Text
  isRecurring         Boolean           @default(false)
  recurrenceRule      String?
  parentTransactionId String?
  status              TransactionStatus @default(COMPLETED)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  property           Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit               Unit?               @relation(fields: [unitId], references: [id], onDelete: SetNull)
  tenant             Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  vendor             Vendor?             @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  parentTransaction  Transaction?        @relation("RecurringTransactions", fields: [parentTransactionId], references: [id], onDelete: SetNull)
  childTransactions  Transaction[]       @relation("RecurringTransactions")
  maintenanceRequest MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id], onDelete: SetNull)
  maintenanceRequestId String?

  @@index([propertyId, date])
  @@index([category])
}

model MaintenanceRequest {
  id                      String              @id @default(cuid())
  propertyId              String
  unitId                  String?
  tenantId                String?
  vendorId                String?
  title                   String
  description             String?             @db.Text
  priority                MaintenancePriority @default(MEDIUM)
  status                  MaintenanceStatus   @default(SUBMITTED)
  photos                  String[]
  estimatedCompletionDate DateTime?
  completedDate           DateTime?
  resolutionNotes         String?             @db.Text
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  property     Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit         Unit?             @relation(fields: [unitId], references: [id], onDelete: SetNull)
  tenant       Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  vendor       Vendor?           @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  transactions Transaction[]
  notes        MaintenanceNote[]

  @@index([status])
}

model MaintenanceNote {
  id                   String   @id @default(cuid())
  maintenanceRequestId String
  content              String   @db.Text
  createdAt            DateTime @default(now())

  maintenanceRequest MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)
}

model Vendor {
  id        String   @id @default(cuid())
  userId    String
  name      String
  trade     String
  phone     String?
  email     String?
  website   String?
  notes     String?  @db.Text
  rating    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  maintenanceRequests MaintenanceRequest[]
  transactions        Transaction[]
  cleaningTasks       CleaningTask[]
}

model Document {
  id         String   @id @default(cuid())
  propertyId String?
  unitId     String?
  tenantId   String?
  leaseId    String?
  fileUrl    String
  fileName   String
  fileType   String
  label      String?
  uploadDate DateTime @default(now())
  createdAt  DateTime @default(now())

  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit     Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  lease    Lease?    @relation(fields: [leaseId], references: [id], onDelete: SetNull)
}

model CommunicationLog {
  id        String              @id @default(cuid())
  tenantId  String
  date      DateTime
  method    CommunicationMethod
  note      String              @db.Text
  createdAt DateTime            @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─── Short-Term Rental (STR) Models ─────────────────────────────────────────

model Guest {
  id        String           @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  platform  BookingPlatform?
  notes     String?          @db.Text
  rating    Int?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]
}

model Booking {
  id                 String          @id @default(cuid())
  unitId             String
  guestId            String
  checkInDate        DateTime
  checkOutDate       DateTime
  nightlyRate        Decimal
  totalAmount        Decimal
  platform           BookingPlatform?
  confirmationNumber String?
  status             BookingStatus   @default(CONFIRMED)
  notes              String?         @db.Text
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  unit         Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)
  guest        Guest         @relation(fields: [guestId], references: [id], onDelete: Cascade)
  cleaningTask CleaningTask?

  @@index([checkInDate])
  @@index([checkOutDate])
}

model CleaningTask {
  id             String         @id @default(cuid())
  bookingId      String?        @unique
  unitId         String
  vendorId       String?
  scheduledDate  DateTime
  status         CleaningStatus @default(PENDING)
  checklistItems Json?
  notes          String?        @db.Text
  cost           Decimal?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  unit    Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  vendor  Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
}

// ─── Notifications ──────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String   @db.Text
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}
